#!/bin/bash
vol=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null)
if echo "$vol" | grep -q "MUTED"; then
    echo " ´Çª mute "
else
    val=$(echo "$vol" | awk '{print int($2*100)}')
    if [ "$val" -lt 33 ]; then
        icon="´Çª"
    elif [ "$val" -lt 66 ]; then
        icon="´Çº"
    else
        icon="´Ç¿"
    fi
    echo " $icon ${val}% "
fi